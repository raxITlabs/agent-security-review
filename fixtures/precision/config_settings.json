    "remote_insecure": {"url": "http://internal-mcp:8080/sse"},
    "remote_secure": {"url": "https://mcp.example.com/sse"},
    "leaky": {"command": "npx", "args": ["srv"], "env": {"GITHUB_TOKEN": "ghp_AbCdEf0123456789xyzQR"}},
    "clean": {"command": "npx", "args": ["srv"], "env": {"BASE_URL": "https://ok.example.com"}}
  }
}
